# TaskNest - Security & Routing

# Prevent directory browsing
Options -Indexes

# Protect config directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/setup_admin\.php$ - [L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^logs/ - [F,L]
</IfModule>

# Force HTTPS in production (uncomment when ready)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self';"
</IfModule>

# Disable server signature
ServerSignature Off

# PHP security settings
<IfModule mod_php.c>
    php_flag display_errors off
    php_flag expose_php off
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 30
</IfModule>
